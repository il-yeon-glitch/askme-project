{
  "name": "askme",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w packages/server\" \"npm run dev -w packages/client\"",
    "build": "npm run build -w packages/client",
    "start": "npm run start -w packages/server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
